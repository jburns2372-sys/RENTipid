generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Users and Roles Foundation
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  mobile_number String?
  full_name     String
  account_type  String // "Individual" | "Business"
  role          String // "Guest" | "Renter" | "Individual Provider" | "Business Provider" | "Admin" | "Finance Admin" | "Compliance Admin" | "Super Admin"
  status        String // "Pending" | "Verified" | "Suspended" | "Blacklisted"
  password_hash String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  profile               UserProfile?
  businessProfile       BusinessProfile?
  listings              Listing[]
  auditLogs             AuditLog[]
  apiSecurityLogs       ApiSecurityLog[]
  aiBotLogs             AIBotLog[]
  verificationDocuments VerificationDocument[]

  // Bookings and Notifications
  renterBookings   Booking[]      @relation("RenterBookings")
  providerBookings Booking[]      @relation("ProviderBookings")
  notifications    Notification[]

  // Finance
  payments      Payment[]
  ledgerEntries FinanceLedger[]

  // Marketing & Social
  socialAccounts   SocialAccount[]
  campaignsCreated MarketingCampaign[]
  postsCreated     MarketingPost[]          @relation("PostCreator")
  postsApproved    MarketingPost[]          @relation("PostApprover")
  optIns           ProviderPromotionOptIn[]

  // Phase 10: Beta & UAT Tracking
  is_test_data Boolean @default(false)
  beta_label   String? // e.g. "Internal Tester", "Provider Beta"

  // Phase 15: Mobile & Compliance
  accountDeletionRequests AccountDeletionRequest[]
}

model UserProfile {
  id                  String  @id @default(cuid())
  user_id             String  @unique
  user                User    @relation(fields: [user_id], references: [id])
  address             String?
  city                String?
  province            String?
  country             String?
  profile_photo       String?
  verification_status String // "Unverified" | "Pending" | "Verified" | "Rejected"
  trust_score         Int     @default(0)
}

model BusinessProfile {
  id                           String  @id @default(cuid())
  user_id                      String  @unique
  user                         User    @relation(fields: [user_id], references: [id])
  business_name                String
  business_registration_number String?
  business_address             String?
  authorized_representative    String?
  verification_status          String // "Unverified" | "Pending" | "Verified" | "Rejected"
}

// Category Foundation
model Category {
  id                      String  @id @default(cuid())
  name                    String
  slug                    String  @unique
  description             String?
  icon                    String?
  risk_level              String // "Low" | "Medium" | "High" | "Regulated"
  requires_admin_approval Boolean @default(false)
  requires_deposit        Boolean @default(false)
  requires_insurance      Boolean @default(false)
  requires_permit         Boolean @default(false)
  is_active               Boolean @default(true)

  requirements CategoryRequirement?
  listings     Listing[]
}

model VerificationDocument {
  id               String    @id @default(cuid())
  user_id          String
  user             User      @relation(fields: [user_id], references: [id])
  document_type    String // "ID" | "Selfie" | "BusinessPermit" | "ProofOfAddress" | "ProofOfOwnership"
  file_url         String
  status           String // "Submitted" | "Under Review" | "Approved" | "Rejected" | "Expired"
  rejection_reason String?
  uploaded_at      DateTime  @default(now())
  reviewed_by      String?
  reviewed_at      DateTime?
}

model CategoryRequirement {
  id                          String   @id @default(cuid())
  category_id                 String   @unique
  category                    Category @relation(fields: [category_id], references: [id])
  required_provider_documents String? // JSON string
  required_renter_documents   String? // JSON string
  deposit_rule                String?
  approval_rule               String?
  prohibited_conditions       String?
  notes                       String?
}

// Listings Foundation
model Listing {
  id          String   @id @default(cuid())
  provider_id String
  provider    User     @relation(fields: [provider_id], references: [id])
  category_id String
  category    Category @relation(fields: [category_id], references: [id])
  title       String
  description String?

  // Location
  location String?
  city     String?
  province String?
  country  String?

  // Pricing
  rental_type       String // "Hourly" | "Daily" | "Weekly" | "Monthly"
  hourly_rate       Float?
  daily_rate        Float?
  weekly_rate       Float?
  monthly_rate      Float?
  security_deposit  Float?
  replacement_value Float?

  // Details
  quantity           Int     @default(1)
  condition          String? // "New" | "Like New" | "Good" | "Fair" | "Used"
  pickup_available   Boolean @default(true)
  delivery_available Boolean @default(false)
  delivery_fee       Float?

  // Policies
  min_duration         Int?
  max_duration         Int?
  late_penalty         String?
  damage_policy        String?
  rules                String?
  included_accessories String?
  excluded_accessories String?
  special_instructions String?

  // Availability
  availability_start DateTime?
  availability_end   DateTime?

  // Status
  status           String // "Draft" | "Submitted for Review" | "Under Review" | "Approved" | "Published" | "Rejected" | "Suspended" | "Unavailable" | "Archived"
  rejection_reason String?

  published_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  photos            ListingPhoto[]
  documents         ListingDocument[]
  bookings          Booking[]
  inspectionReports InspectionReport[]
  marketingPosts    MarketingPost[]
  optIns            ProviderPromotionOptIn[]

  // Phase 10: Beta & UAT Tracking
  is_test_data Boolean @default(false)
  beta_label   String?
}

model ListingPhoto {
  id            String   @id @default(cuid())
  listing_id    String
  listing       Listing  @relation(fields: [listing_id], references: [id], onDelete: Cascade)
  file_path     String
  file_type     String
  file_size     Int
  display_order Int      @default(0)
  is_cover      Boolean  @default(false)
  uploaded_at   DateTime @default(now())
}

model ListingDocument {
  id               String    @id @default(cuid())
  listing_id       String
  listing          Listing   @relation(fields: [listing_id], references: [id], onDelete: Cascade)
  document_type    String
  file_path        String
  file_type        String
  file_size        Int
  status           String // "Submitted" | "Under Review" | "Approved" | "Rejected" | "Expired"
  rejection_reason String?
  uploaded_at      DateTime  @default(now())
  reviewed_by      String?
  reviewed_at      DateTime?
}

model Booking {
  id          String  @id @default(cuid())
  listing_id  String
  listing     Listing @relation(fields: [listing_id], references: [id])
  renter_id   String
  renter      User    @relation("RenterBookings", fields: [renter_id], references: [id])
  provider_id String
  provider    User    @relation("ProviderBookings", fields: [provider_id], references: [id])

  start_date           DateTime
  end_date             DateTime
  start_time           String?
  end_time             String?
  rental_duration      Int
  rental_duration_unit String

  selected_rate_type     String
  base_rental_amount     Float
  deposit_amount         Float
  platform_fee           Float?
  estimated_total_amount Float

  pickup_option      String // "Pickup" | "Delivery"
  delivery_requested Boolean @default(false)
  delivery_address   String?
  delivery_fee       Float?

  renter_notes        String?
  provider_notes      String?
  cancellation_reason String?
  rejection_reason    String?

  status         String // "Pending Provider Approval" | "Approved" | "Pending Payment" | "Confirmed" | "Ongoing" | "Returned" | "Completed" | "Cancelled by Renter" | "Cancelled by Provider" | "Rejected" | "Expired"
  payment_status String @default("Not Required Yet")

  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  approved_at  DateTime?
  rejected_at  DateTime?
  cancelled_at DateTime?
  completed_at DateTime?

  statusHistory       BookingStatusHistory[]
  payment             Payment?
  rentalAgreement     RentalAgreement?
  ledgerEntries       FinanceLedger[]
  gatewayTransactions GatewayTransaction[]

  inspectionReports InspectionReport[]
  turnoverRecords   TurnoverRecord[]
  damageClaims      DamageClaim[]
  disputes          DisputeCase[]
  depositActions    DepositAction[]
  refundRequests    RefundRequest[]
  providerPayouts   ProviderPayout[]

  // Phase 10: Beta & UAT Tracking
  is_test_data Boolean @default(false)
  beta_label   String?
}

model BookingStatusHistory {
  id         String   @id @default(cuid())
  booking_id String
  booking    Booking  @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  old_status String
  new_status String
  changed_by String
  notes      String?
  created_at DateTime @default(now())
}

// Placeholder Models
model Payment {
  id         String  @id @default(cuid())
  booking_id String  @unique
  booking    Booking @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  user_id    String
  user       User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  amount                 Float
  payment_method         String // "Mock Gateway" | "Credit Card" | "E-Wallet"
  status                 String // "Pending" | "Completed" | "Failed" | "Refunded"
  type                   String // "Rental Payment" | "Deposit Refund" | "Payout" | "Penalty"
  transaction_id         String?             @unique
  gateway_transaction_id String?             @unique
  gateway_transaction    GatewayTransaction? @relation(fields: [gateway_transaction_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

// ----------------------------------------------------------------------
// Phase 14: Payment Gateway Sandbox Integration
// ----------------------------------------------------------------------

model GatewayTransaction {
  id         String   @id @default(cuid())
  booking_id String
  booking    Booking  @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  payment    Payment?

  provider             String // "PayMongo" | "Xendit" | "Maya" | "Mock" | "Manual"
  provider_mode        String // "Sandbox" | "Live" | "Internal"
  gateway_reference    String? @unique
  gateway_checkout_url String?
  gateway_status       String // "Created" | "Checkout Pending" | "Paid Sandbox" | "Failed Sandbox" | "Expired" | "Cancelled" | "Refunded Placeholder" | "Error"

  amount   Float
  currency String @default("PHP")

  raw_event_summary   String?
  webhook_event_type  String?
  webhook_received_at DateTime?

  verified              Boolean @default(false)
  verification_status   String // "Not Verified" | "Verified" | "Failed" | "Skipped Sandbox"
  reconciliation_status String // "Pending" | "Matched" | "Mismatch" | "Manual Review Required"

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  reconciliationLogs PaymentReconciliationLog[]
}

model PaymentWebhookLog {
  id                     String   @id @default(cuid())
  provider               String
  event_type             String
  gateway_reference      String?
  booking_id             String?
  payment_transaction_id String?
  headers_summary        String?
  payload_summary        String?
  verification_status    String
  processing_status      String // "Received" | "Processed" | "Ignored" | "Failed" | "Duplicate"
  error_message          String?
  received_at            DateTime @default(now())
}

model PaymentReconciliationLog {
  id                     String             @id @default(cuid())
  booking_id             String
  payment_transaction_id String?
  gateway_transaction_id String
  gateway_transaction    GatewayTransaction @relation(fields: [gateway_transaction_id], references: [id], onDelete: Cascade)

  expected_amount   Float
  received_amount   Float
  expected_currency String   @default("PHP")
  received_currency String   @default("PHP")
  status            String // "Matched" | "Mismatch"
  notes             String?
  created_at        DateTime @default(now())
}

model FinanceLedger {
  id         String   @id @default(cuid())
  user_id    String?
  user       User?    @relation(fields: [user_id], references: [id])
  booking_id String?
  booking    Booking? @relation(fields: [booking_id], references: [id])

  transaction_type String // "Platform Fee" | "Provider Payout" | "Escrow Deposit" | "Refund"
  amount           Float
  balance_type     String // "Credit" | "Debit"
  description      String?

  created_at DateTime @default(now())
}

model RentalAgreement {
  id         String  @id @default(cuid())
  booking_id String  @unique
  booking    Booking @relation(fields: [booking_id], references: [id], onDelete: Cascade)

  agreement_text       String // Contains the full text that was agreed upon
  accepted_by_renter   Boolean   @default(false)
  accepted_at          DateTime?
  accepted_by_provider Boolean   @default(false)
  provider_accepted_at DateTime?

  created_at DateTime @default(now())
}

model SystemSettings {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updated_at  DateTime @updatedAt
}

model InspectionReport {
  id          String  @id @default(cuid())
  booking_id  String
  booking     Booking @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  listing_id  String
  listing     Listing @relation(fields: [listing_id], references: [id])
  renter_id   String
  provider_id String

  inspection_type String // "Pre-Rental" | "Post-Rental"
  status          String // "Draft" | "Submitted by Provider" | "Confirmed by Renter" | "Submitted by Renter" | "Confirmed by Provider" | "Rejected" | "Requires Review" | "Completed"

  condition_summary   String
  odometer_reading    String?
  fuel_level          String?
  meter_reading       String?
  quantity_checked    Int?
  accessories_checked String?
  provider_notes      String?
  renter_notes        String?

  submitted_by String?
  confirmed_by String?
  submitted_at DateTime?
  confirmed_at DateTime?

  photos InspectionPhoto[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model InspectionPhoto {
  id                   String           @id @default(cuid())
  inspection_report_id String
  inspection_report    InspectionReport @relation(fields: [inspection_report_id], references: [id], onDelete: Cascade)
  booking_id           String

  file_path      String
  file_type      String
  file_size      Int
  caption        String?
  photo_category String // "Front View" | "Back View" | "Left Side" | "Right Side" | "Serial Number" | "Accessories" | "Existing Damage" | "Meter/Odometer" | "General Condition" | "Return Condition" | "Damage Evidence" | "Other"
  uploaded_by    String
  uploaded_at    DateTime @default(now())
}

model TurnoverRecord {
  id          String  @id @default(cuid())
  booking_id  String
  booking     Booking @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  listing_id  String
  renter_id   String
  provider_id String

  turnover_type      String // "Release to Renter" | "Return to Provider"
  turnover_status    String // "Pending" | "Completed" | "Rejected" | "Requires Review"
  pickup_or_delivery String
  turnover_location  String?
  turnover_datetime  DateTime?

  handed_over_by     String?
  received_by        String?
  confirmation_notes String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model DamageClaim {
  id          String  @id @default(cuid())
  booking_id  String
  booking     Booking @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  listing_id  String
  renter_id   String
  provider_id String

  claim_number String @unique
  claim_type   String // "Damage" | "Missing Item" | "Late Return" | "Cleaning Fee" | "Excess Usage" | "Other"
  claim_status String // "Draft" | "Submitted" | "Renter Response Pending" | "Under Admin Review" | "Approved" | "Partially Approved" | "Rejected" | "Resolved" | "Cancelled"

  claim_description          String
  claimed_amount             Float
  deposit_amount             Float
  requested_deduction_amount Float

  provider_evidence_summary String?
  renter_response           String?
  admin_decision            String?

  approved_deduction_amount Float?
  refund_to_renter_amount   Float?

  decided_by String?
  decided_at DateTime?

  photos   DamageClaimPhoto[]
  disputes DisputeCase[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model DamageClaimPhoto {
  id              String      @id @default(cuid())
  damage_claim_id String
  damage_claim    DamageClaim @relation(fields: [damage_claim_id], references: [id], onDelete: Cascade)

  file_path   String
  file_type   String
  file_size   Int
  caption     String?
  uploaded_by String
  uploaded_at DateTime @default(now())
}

model DisputeCase {
  id              String       @id @default(cuid())
  booking_id      String
  booking         Booking      @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  damage_claim_id String?
  damage_claim    DamageClaim? @relation(fields: [damage_claim_id], references: [id])

  opened_by      String
  dispute_type   String // "Damage Claim" | "Deposit Release" | "Return Condition" | "Missing Item" | "Late Return" | "Payment Concern" | "Other"
  dispute_status String // "Open" | "Waiting for Renter" | "Waiting for Provider" | "Under Review" | "Resolved" | "Closed" | "Cancelled"

  summary            String
  provider_statement String?
  renter_statement   String?
  admin_notes        String?
  final_decision     String?

  decided_by String?
  decided_at DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model DepositAction {
  id                String  @id @default(cuid())
  booking_id        String
  booking           Booking @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  deposit_ledger_id String?

  action_type  String // "Hold" | "Release Full" | "Release Partial" | "Deduct Full" | "Deduct Partial" | "Hold for Dispute"
  amount       Float
  reason       String?
  performed_by String

  created_at DateTime @default(now())
}

model Review {
  id String @id @default(cuid())
}

// System Logs
model Notification {
  id         String   @id @default(cuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  title      String
  message    String
  type       String
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())
}

model AuditLog {
  id            String   @id @default(cuid())
  actor_user_id String?
  actor         User?    @relation(fields: [actor_user_id], references: [id])
  action        String
  module        String
  target_id     String?
  details       String?
  ip_address    String?
  created_at    DateTime @default(now())
}

model ApiSecurityLog {
  id                     String   @id @default(cuid())
  event_code             String
  outcome                String
  actor_user_id          String?
  actor                  User?    @relation(fields: [actor_user_id], references: [id])
  subject_reference_hash String?
  ip_reference_hash      String?
  device_reference_hash  String?
  target_reference_hash  String?
  safe_route_family      String
  http_method            String
  policy_family          String?
  threshold_category     String?
  distinct_target_count  Int?
  correlation_id         String?
  environment            String
  lifecycle              String
  sanitized_metadata     String?
  occurred_at            DateTime
  created_at             DateTime @default(now())

  @@index([event_code, occurred_at])
  @@index([ip_reference_hash, occurred_at])
  @@index([correlation_id])
}

model AIBotLog {
  id               String   @id @default(cuid())
  user_id          String?
  user             User?    @relation(fields: [user_id], references: [id])
  bot_name         String
  module           String
  prompt           String?
  response_summary String?
  action_requested String?
  action_status    String?
  created_at       DateTime @default(now())
}

model SystemSetting {
  id            String   @id @default(cuid())
  setting_key   String   @unique
  setting_value String
  description   String?
  updated_by    String?
  updated_at    DateTime @updatedAt
}

// ----------------------------------------------------------------------
// Phase 4: Identity & Session Security Telemetry
// ----------------------------------------------------------------------
model AuthenticationSecurityLog {
  id                     String   @id @default(cuid())
  event_code             String
  outcome                String
  actor_user_id          String?
  subject_reference_hash String?
  ip_reference_hash      String?
  device_reference_hash  String?
  session_reference_hash String?
  hmac_key_version       String
  environment            String
  lifecycle              String
  retention_class        String
  expires_at             DateTime
  sanitized_metadata     String?
  occurred_at            DateTime @default(now())

  @@index([event_code, occurred_at])
  @@index([subject_reference_hash, occurred_at])
  @@index([ip_reference_hash, occurred_at])
  @@index([device_reference_hash, occurred_at])
  @@index([expires_at])
}

// ----------------------------------------------------------------------
// Phase 9: Error & System Monitoring
// ----------------------------------------------------------------------

model SystemErrorLog {
  id                  String   @id @default(cuid())
  user_id             String?
  module              String
  route               String?
  error_message       String
  stack_trace_private String?
  severity            String // "Info" | "Warning" | "Error" | "Critical"
  created_at          DateTime @default(now())
}

// ----------------------------------------------------------------------
// Phase 8: Social Promotion Engine and Marketing Models
// ----------------------------------------------------------------------

model SocialAccount {
  id                      String    @id @default(cuid())
  owner_user_id           String?
  owner                   User?     @relation(fields: [owner_user_id], references: [id])
  business_provider_id    String? // Optional string ref to BusinessProfile
  platform                String
  account_name            String
  account_handle          String
  account_type            String
  connection_status       String
  access_token_encrypted  String?
  refresh_token_encrypted String?
  token_expires_at        DateTime?
  scopes                  String?
  last_connected_at       DateTime?
  disconnected_at         DateTime?
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt
}

model MarketingCampaign {
  id                 String    @id @default(cuid())
  created_by_id      String
  created_by         User      @relation(fields: [created_by_id], references: [id])
  campaign_name      String
  campaign_type      String
  campaign_goal      String
  target_audience    String?
  target_country     String?
  target_city        String?
  target_language    String?
  start_date         DateTime?
  end_date           DateTime?
  budget_placeholder Float?
  campaign_status    String
  approval_status    String
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  posts     MarketingPost[]
  approvals CampaignApproval[]
  assets    PromotionAsset[]
  utmLinks  UTMLink[]
  analytics CampaignAnalytics[]

  // Phase 10: Beta & UAT Tracking
  is_test_data Boolean @default(false)
  beta_label   String?
}

model MarketingPost {
  id               String            @id @default(cuid())
  campaign_id      String
  campaign         MarketingCampaign @relation(fields: [campaign_id], references: [id])
  listing_id       String?
  listing          Listing?          @relation(fields: [listing_id], references: [id])
  provider_id      String? // String ref to User
  platform         String
  post_type        String
  post_title       String?
  caption          String?
  hashtags         String?
  media_type       String?
  media_file_path  String?
  media_prompt     String?
  destination_url  String?
  tracking_url     String?
  scheduled_at     DateTime?
  published_at     DateTime?
  post_status      String
  approval_status  String
  rejection_reason String?

  created_by_id  String?
  created_by     User?   @relation("PostCreator", fields: [created_by_id], references: [id])
  approved_by_id String?
  approved_by    User?   @relation("PostApprover", fields: [approved_by_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  approvals    CampaignApproval[]
  assets       PromotionAsset[]
  utmLinks     UTMLink[]
  analytics    CampaignAnalytics[]
  queueEntries SocialPostQueue[]
}

model CampaignApproval {
  id              String            @id @default(cuid())
  campaign_id     String
  campaign        MarketingCampaign @relation(fields: [campaign_id], references: [id])
  post_id         String?
  post            MarketingPost?    @relation(fields: [post_id], references: [id])
  requested_by    String // User ID string
  reviewed_by     String? // User ID string
  approval_status String
  review_notes    String?
  requested_at    DateTime          @default(now())
  reviewed_at     DateTime?
}

model PromotionAsset {
  id              String             @id @default(cuid())
  campaign_id     String?
  campaign        MarketingCampaign? @relation(fields: [campaign_id], references: [id])
  post_id         String?
  post            MarketingPost?     @relation(fields: [post_id], references: [id])
  asset_type      String
  file_path       String?
  prompt_used     String?
  generated_by_ai Boolean            @default(false)
  uploaded_by     String?
  created_at      DateTime           @default(now())
}

model UTMLink {
